{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/debug.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/simple.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/minimal.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/debug",
      "dest": "/api/debug.ts"
    },
    {
      "src": "/api/simple",
      "dest": "/api/simple.ts"
    },
    {
      "src": "/api/minimal",
      "dest": "/api/minimal.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/api/minimal.ts"
    }
  ]
}
